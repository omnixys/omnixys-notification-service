generator client {
  provider = "prisma-client"
  output   = "../src/prisma/generated"
}

datasource db {
  provider = "postgresql"
  schemas  = ["notification"]
}

//
// ──────────────────────────────────────────────────────────
// ENUMS
// ──────────────────────────────────────────────────────────
//
enum Channel {
  IN_APP
  PUSH
  EMAIL
  SMS
  WHATSAPP

  @@map("channel")
  @@schema("notification")
}

enum ContentFormat {
  TEXT
  HTML
  MARKDOWN

  @@map("content_format")
  @@schema("notification")
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT

  @@map("priority")
  @@schema("notification")
}

enum NotificationStatus {
  PENDING
  PROCESSING
  SENT
  DELIVERED
  FAILED
  CANCELLED
  EXPIRED
  ARCHIVED

  @@map("notification_status")
  @@schema("notification")
}

enum DeliveryAttemptStatus {
  SUCCESS
  FAILED

  @@map("delivery_attempt_status")
  @@schema("notification")
}

enum WebhookEventType {
  DELIVERED
  BOUNCED
  OPENED
  CLICKED
  REJECTED

  @@schema("notification")
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  templates     Template[]
  notifications Notification[]

  @@map("tenant")
  @@schema("notification")
}

//
// ──────────────────────────────────────────────────────────
// TEMPLATE
// ──────────────────────────────────────────────────────────
//
model Template {
  id       String  @id @default(cuid()) @map("id")
  tenantId String? @map("tenant_id")
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  key     String  @map("key")
  channel Channel

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tags          String[]          @default([]) @map("tags")
  versions      TemplateVersion[]
  notifications Notification[]

  @@unique([tenantId, key, channel])
  @@map("template")
  @@schema("notification")
}

model TemplateVersion {
  id         String   @id @default(cuid())
  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  locale  String @default("de-DE")
  version Int

  subject String?
  body    String
  format  ContentFormat

  variables Json @default("{}")

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  @@unique([templateId, locale, version])
  @@index([templateId, locale, isActive])
  @@map("template_version")
  @@schema("notification")
}

//
// ──────────────────────────────────────────────────────────
// NOTIFICATION INSTANCE
// ──────────────────────────────────────────────────────────
//
model Notification {
  id String @id @default(cuid()) @map("id")

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  // ── Recipient ───────────────────────────────────────────
  recipientUsername String  @map("recipient_username")
  recipientId       String? @map("recipient_id")
  recipientAddress  String? @map("recipient_address")

  // ── Template & Rendering ─────────────────────────────────
  templateId      String?   @map("template_id")
  template        Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  templateVersion Int?

  variables Json @default("{}") @map("variables")
  metadata  Json @default("{}")

  channel  Channel  @map("channel")
  priority Priority @default(NORMAL) @map("priority")
  category String?  @map("category")

  // ── Lifecycle ────────────────────────────────────────────
  status NotificationStatus @default(PENDING) @map("status")

  readAt      DateTime?
  deliveredAt DateTime?
  expiresAt   DateTime?
  archivedAt  DateTime?
  purgedAt    DateTime?

  /// Marks notifications containing secrets
  sensitive Boolean @default(false) @map("sensitive")

  // ── Audit ────────────────────────────────────────────────
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")

  provider    String?
  providerRef String?

  @@index([status, createdAt])
  @@index([tenantId, status])
  @@index([recipientUsername, createdAt])
  @@index([expiresAt])
  @@map("notification")
  @@schema("notification")
}
